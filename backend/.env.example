# ========================================
# InvestWise - Environment Variables
# ========================================
# Copy this file to .env and customize values
# NEVER commit .env to version control!
# ========================================

# ----------------------------------------
# Application
# ----------------------------------------
NODE_ENV=development
PORT=3001

# ----------------------------------------
# MongoDB
# ----------------------------------------
MONGODB_URI=mongodb://localhost:27017/investwise
MONGO_ROOT_USERNAME=investwise_admin
MONGO_ROOT_PASSWORD=investwise_secret_123

# ----------------------------------------
# Redis
# ----------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_123
REDIS_DB=0

# ----------------------------------------
# Kafka
# ----------------------------------------
KAFKA_BROKERS=localhost:9092

# ----------------------------------------
# JWT Authentication
# ----------------------------------------
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_change_in_production_make_it_long_and_random
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_also_random
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ----------------------------------------
# Encryption (for 2FA secrets, backup codes)
# ----------------------------------------
# Must be exactly 32 characters for AES-256
ENCRYPTION_KEY=32_character_encryption_key_here!

# ----------------------------------------
# Two-Factor Authentication
# ----------------------------------------
TOTP_ISSUER=InvestWise
BACKUP_CODES_COUNT=10

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ----------------------------------------
# External APIs
# ----------------------------------------
# Yahoo Finance (no API key required for basic use)
YAHOO_FINANCE_API_URL=https://query1.finance.yahoo.com

# ----------------------------------------
# AI Service (Ollama)
# ----------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ----------------------------------------
# Email (for alerts and digests)
# ----------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=InvestWise <noreply@investwise.app>

# ----------------------------------------
# Frontend URL (for CORS)
# ----------------------------------------
FRONTEND_URL=http://localhost:5173

# ----------------------------------------
# Logging
# ----------------------------------------
LOG_LEVEL=debug
