# Backend Environment Variables

# Server
NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/investwise

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=investwise-backend
KAFKA_REQUEST_TOPIC=portfolio-analysis-requests
KAFKA_RESULT_TOPIC=portfolio-analysis-results

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
ANALYSIS_RATE_LIMIT_MAX=5

# Market Data API (Finnhub)
FINNHUB_API_KEY=your-finnhub-api-key

# CORS
FRONTEND_URL=http://localhost:5173

# Batch Processing
BATCH_SIZE=50
BATCH_TIMEOUT_MS=5000
