# ========================================
# InvestWise Backend - Environment Variables
# ========================================
# Local development configuration
# ========================================

NODE_ENV=development
PORT=3001

# MongoDB (local Docker with auth)
MONGODB_URI=mongodb://investwise_admin:investwise_secret_123@localhost:27017/investwise?authSource=admin

# Redis (local with Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_123
REDIS_DB=0

# Kafka (local)
KAFKA_BROKERS=localhost:9092

# JWT Secrets (change these in production!)
JWT_SECRET=dev_jwt_secret_key_not_for_production_use_only
JWT_REFRESH_SECRET=dev_refresh_secret_key_not_for_production_use_only
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption Key (must be exactly 32 characters)
ENCRYPTION_KEY=dev_32_char_key_not_for_prod_!!

# 2FA Configuration
TOTP_ISSUER=InvestWise
BACKUP_CODES_COUNT=10

# Ollama AI
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Frontend URL
FRONTEND_URL=http://localhost:5173
